# ── Copy to .env.local and fill in your values ────────────────────────────
# .env.local is gitignored — safe to put secrets here.

# ── Auth mode ──────────────────────────────────────────────────────────────
# false → local canvas only (no login, no DB)
# true  → Google SSO + Supabase dashboard + realtime sync
# You normally don't need to set this — .env and .env.production handle it.
# VITE_AUTH_ENABLED=false

# ── Anthropic — LLM eval (client-side until backend is deployed) ───────────
VITE_ANTHROPIC_API_KEY=

# ── Supabase — required when VITE_AUTH_ENABLED=true ───────────────────────
# Find both in: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth redirect — must match exactly in:
#   1. Supabase dashboard → Auth → URL Configuration → Redirect URLs
#   2. Google Cloud Console → OAuth credentials → Authorized redirect URIs
#      (add: https://your-project.supabase.co/auth/v1/callback  ← Supabase handles this)
VITE_REDIRECT_URL=http://localhost:5173

# ── Backend API — set when stratum-api is deployed ─────────────────────────
# VITE_API_URL=http://localhost:3001
