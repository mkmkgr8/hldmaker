# Copy to .env.local and fill in your values.
# .env.local is gitignored — safe for secrets.
# Production values go in your deployment pipeline env vars, not in any file.

# ── Auth ───────────────────────────────────────────────────────────────────
# false = local canvas only (no login)   ← default in .env
# true  = Google SSO + Supabase (set this in your deployment pipeline for prod)
VITE_AUTH_ENABLED=false

# ── Anthropic ── LLM eval (client-side until backend is deployed) ──────────
VITE_ANTHROPIC_API_KEY=

# ── Supabase ── required when VITE_AUTH_ENABLED=true ──────────────────────
# Supabase dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Must match: Supabase Auth → URL Configuration → Redirect URLs
VITE_REDIRECT_URL=http://localhost:5173

# ── Backend API ── when stratum-api is deployed ────────────────────────────
# VITE_API_URL=http://localhost:3001
